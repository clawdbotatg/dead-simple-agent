# Copy this to .env and fill in your values

# Ollama (default provider)
OLLAMA_URL=http://localhost:11434/api/chat

# Venice AI — get a key at https://venice.ai
# VENICE_API_KEY=your-key-here
# VENICE_BASE_URL=https://api.venice.ai/api/v1

# Anthropic — get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Bankr LLM Gateway — get a key at https://bankr.bot/api
# Supports Claude, GPT, Gemini, Kimi, Qwen models through a single API
# BANKR_API_KEY=your-key-here
# BANKR_BASE_URL=https://llm.bankr.bot/v1

# OpenRouter — get a key at https://openrouter.ai/settings/keys
# Routes to 300+ models through a single API
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI-compatible (template for adding your own)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
